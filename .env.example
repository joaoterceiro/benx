# Contrato de variáveis de ambiente do Benx Clone.
# Copie para .env e ajuste em produção. Os defaults batem com o docker-compose de dev.

# Postgres
DATABASE_URL=postgres://benx:benx@localhost:5432/benx

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=benx-midia
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Admin inicial (criado pelo db:seed). Troque em produção.
ADMIN_EMAIL=admin@benx.local
ADMIN_SENHA=benx1234

# URL publica do site (usada em metadata/OG, sitemap e robots)
NEXT_PUBLIC_SITE_URL=https://www.benx.com.br
